# =============================================================================
# Kaksh AI Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — only configure the providers you want to use.
# You can also use server-providers.yml for configuration (see docs).
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=


# --- TTS (Text-to-Speech) ----------------------------------------------------

TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=

TTS_ELEVENLABS_API_KEY=
TTS_ELEVENLABS_BASE_URL=

# --- ASR (Automatic Speech Recognition) --------------------------------------

ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=

# --- PDF Processing -----------------------------------------------------------

PDF_UNPDF_API_KEY=
PDF_UNPDF_BASE_URL=

PDF_MINERU_API_KEY=
PDF_MINERU_BASE_URL=

# --- Image Generation ---------------------------------------------------------

IMAGE_NANO_BANANA_API_KEY=
IMAGE_NANO_BANANA_BASE_URL=

# --- Video Generation ---------------------------------------------------------

VIDEO_VEO_API_KEY=
VIDEO_VEO_BASE_URL=

VIDEO_SORA_API_KEY=
VIDEO_SORA_BASE_URL=

# --- Web Search ---------------------------------------------------------------

FIRECRAWL_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- ElevenLabs (Voice Agent) -------------------------------------------------

ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- Supabase (Database + Auth) -----------------------------------------------
# Self-hosted: run `cd supabase-docker && docker compose up -d`, then copy keys from supabase-docker/.env
# Hosted: get these from your Supabase project dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (Rate Limiting) ---------------------------------------------------
# Self-hosted (Docker): no config needed, defaults to localhost:6379
# Upstash (serverless): set the REST URL and token

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://localhost:6379

# --- Misc ---------------------------------------------------------------------

# Optional server-side default model for API routes like /api/generate-classroom
# Example: anthropic:claude-3-5-haiku-20241022 or google:gemini-3-flash-preview
DEFAULT_MODEL=

# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LLM_THINKING_DISABLED=false
